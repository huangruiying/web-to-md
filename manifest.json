{
  "manifest_version": 3,
  "name": "网页转 Markdown（带资源打包）",
  "version": "0.1.0",
  "description": "一键把网页正文导出为 Markdown，并连同页面图片打包成单个 zip（类似飞书文档导出）。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "导出为 Markdown"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "libs/turndown.js",
        "libs/turndown-plugin-gfm.js",
        "libs/readability.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
